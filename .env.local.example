# ==========================================
# Blog & GitHub Authentication Configuration
# ==========================================

# GitHub OAuth Configuration
# Get these from: https://github.com/settings/developers
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# GitHub Repository Configuration
# Where your blog posts will be stored
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=datarn-io

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
# Scope required: repo (full control)
GITHUB_TOKEN=your_github_personal_access_token

# NextAuth Configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_a_random_secret_here_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ==========================================
# Notes
# ==========================================
# 1. Never commit this file to Git
# 2. Add .env.local to .gitignore
# 3. For production, use environment variables in your hosting platform
# 4. GitHub OAuth callback URL:
#    Development: http://localhost:3000/api/auth/github/callback
#    Production: https://yourdomain.com/api/auth/github/callback

